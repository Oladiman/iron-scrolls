    margin: 0 0 0.75rem;
  }
  .section-text {
    color: var(--sl-color-gray-2);
    font-size: 0.975rem;
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  /* ── Problem grid ── */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .problem-card {
    background: var(--is-color-surface);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    padding: 1.25rem;
  }
  .problem-icon { font-size: 1.6rem; display: block; margin-bottom: 0.6rem; }
  .problem-card strong {
    display: block;
    color: var(--sl-color-white);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .problem-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }

  /* ── Check cards ── */
  .checks-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .check-card {
    background: var(--is-color-surface);
    border: 1px solid var(--sl-color-hairline);
    border-left: 3px solid var(--sl-color-accent);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }
  .check-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }
  .check-icon { font-size: 1.5rem; flex-shrink: 0; }
  .check-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.2;
  }
  .check-command {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.78rem;
    color: var(--sl-color-accent);
    margin-top: 0.15rem;
  }
  .check-benefit, .check-impact {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.65;
    margin: 0 0 0.75rem;
  }
  .check-impact { margin-bottom: 0.6rem; }
  .impact-label {
    font-weight: 700;
    color: var(--sl-color-gray-1);
  }
  .check-reports {
    font-size: 0.78rem;
    color: var(--sl-color-gray-4);
    font-style: italic;
    border-top: 1px solid var(--sl-color-hairline);
    padding-top: 0.6rem;
    margin-top: 0.2rem;
  }

  /* ── Reports grid ── */
  .reports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .report-card {
    background: var(--is-color-surface);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }
  .report-dev { border-top: 3px solid #3a7fd5; }
  .report-owner { border-top: 3px solid var(--sl-color-accent); }
  .report-type {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--sl-color-white);
    margin-bottom: 0.9rem;
  }
  .report-card ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  .report-card li {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    line-height: 1.65;
    margin-bottom: 0.35rem;
  }

  /* ── Steps ── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .step {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--sl-color-hairline);
    align-items: flex-start;
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    background: var(--sl-color-accent);
    color: white;
    border-radius: 50%;
    font-weight: 800;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }
  .step-content strong {
    display: block;
    font-size: 1rem;
    color: var(--sl-color-white);
    margin-bottom: 0.3rem;
  }
  .step-content p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.65;
  }

  /* ── Example ── */
  .example-card {
    background: var(--is-color-surface);
    border: 1px solid var(--sl-color-hairline);
    border-left: 3px solid var(--sl-color-accent);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
  }
  .example-quote {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--sl-color-white);
    line-height: 1.65;
    margin: 0 0 1rem;
  }
  .example-body {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.65;
    margin: 0 0 0.75rem;
  }
  .example-link {
    display: inline-block;
    margin-top: 0.25rem;
    color: var(--sl-color-accent) !important;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
  }
  .example-link:hover { color: var(--sl-color-accent-high) !important; }

  /* ── Final CTA ── */
  .final-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--is-color-surface);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    margin-top: 1rem;
  }
  .final-cta h2 {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--sl-color-white);
    margin: 0 0 0.75rem;
  }
  .final-cta > p:first-of-type {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 1.75rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-sub {
    margin-top: 1.25rem !important;
    font-size: 0.85rem;
    color: var(--sl-color-gray-4);
  }
  .cta-sub a {
    color: var(--sl-color-accent) !important;
    text-decoration: none;
  }
  .cta-sub a:hover { color: var(--sl-color-accent-high) !important; }

</style>

</StarlightPage>
