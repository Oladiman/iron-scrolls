---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
---

<div class="site-title-with-nav">
  <Default {...Astro.props}><slot /></Default>
  <nav class="header-nav" aria-label="Site navigation">
    <a href="/iron-scrolls/try/">Try it</a>
    <a href="/iron-scrolls/blog/">Blog</a>
  </nav>
</div>

<style>
  .site-title-with-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .header-nav a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.2em 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }

  .header-nav a:hover {
    color: var(--sl-color-accent-high);
    border-bottom-color: var(--sl-color-accent);
  }

  /* Hide on very small screens where the header collapses */
  @media (max-width: 400px) {
    .header-nav {
      display: none;
    }
  }
</style>
